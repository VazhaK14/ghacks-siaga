{
  "name": "siaga-app",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "@types/bun": "^1.3.14",
      "hono": "^4.12.27",
      "@trpc/server": "^11.18.0",
      "better-auth": "1.6.23",
      "lucide-react": "^1.23.0",
      "next-themes": "^0.4.6",
      "sonner": "^2.0.7",
      "@trpc/tanstack-react-query": "^11.18.0",
      "@trpc/client": "^11.18.0",
      "@tanstack/react-query": "^5.101.2",
      "@tanstack/react-form": "^1.33.0",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.3.2",
      "tailwind-merge": "^3.6.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "bun run scripts/railway-build.ts",
    "check-types": "turbo run check-types",
    "dev:citizen": "turbo run dev -F citizen",
    "dev:web": "turbo run dev -F web",
    "dev:server": "turbo run dev -F server",
    "db:push": "turbo run db:push -F @siaga-app/db",
    "db:studio": "turbo run db:studio -F @siaga-app/db",
    "db:generate": "turbo run db:generate -F @siaga-app/db",
    "db:migrate": "turbo run db:migrate -F @siaga-app/db",
    "db:deploy": "turbo run db:deploy -F @siaga-app/db",
    "db:seed": "turbo run db:seed -F @siaga-app/db",
    "deploy:setup": "vercel link",
    "dev:vercel": "vercel dev -L",
    "env:preview": "tsx scripts/sync-vercel-env.ts preview",
    "env:production": "tsx scripts/sync-vercel-env.ts production",
    "deploy": "vercel deploy",
    "deploy:prod": "vercel deploy --prod",
    "deploy:check": "vercel deploy --dry",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "start": "bun run scripts/railway-start.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@siaga-app/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@siaga-app/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "^22.13.14",
    "husky": "latest",
    "tsx": "^4.22.5",
    "turbo": "^2.10.2",
    "typescript": "^6",
    "ultracite": "7.9.3",
    "vercel": "^54.18.6"
  },
  "packageManager": "bun@1.3.14"
}
