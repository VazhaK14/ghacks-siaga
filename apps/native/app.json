{
  "expo": {
    "scheme": "siaga-app",
    "userInterfaceStyle": "light",
    "orientation": "portrait",
    "web": {
      "bundler": "metro"
    },
    "name": "SIAGA",
    "slug": "siaga-app",
    "plugins": [
      "expo-font",
      "expo-splash-screen",
      "expo-image",
      "expo-secure-store",
      "@livekit/react-native-expo-plugin",
      "@config-plugins/react-native-webrtc",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SIAGA menggunakan lokasi Anda untuk mempercepat bantuan saat SOS."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "SIAGA menggunakan mikrofon untuk mengubah ucapan Anda menjadi laporan darurat.",
          "speechRecognitionPermission": "SIAGA menggunakan pengenalan suara untuk mengubah ucapan Anda menjadi teks laporan.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "android": {
      "package": "com.anonymous.siagaapp",
      "permissions": [
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.anonymous.siagaapp"
    }
  }
}
