{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown --config-loader tsx",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@hono/trpc-server": "^0.4.2",
    "@siaga-app/api": "workspace:*",
    "@siaga-app/auth": "workspace:*",
    "@siaga-app/db": "workspace:*",
    "@siaga-app/env": "workspace:*",
    "@trpc/server": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "evlog": "^2.19.2",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@siaga-app/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.5",
    "typescript": "^6"
  }
}
