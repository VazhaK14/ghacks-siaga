enum ReportStatus {
  SUBMITTED
  AI_GATHERING
  READY_FOR_REVIEW
  DISPATCH_PENDING
  DISPATCHED
  HELP_EN_ROUTE
  HELP_ARRIVED
  RESOLVED
  CLOSED
  CANCELLED
}

enum ReportCategory {
  UNCATEGORIZED
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentType {
  CRIME
  FIRE
  MEDICAL
  TRAFFIC_ACCIDENT
  NATURAL_DISASTER
  DOMESTIC_VIOLENCE
  MISSING_PERSON
  OTHER
}

enum HandlingMode {
  AI
  HUMAN
}

enum InteractionMode {
  VOICE
  TEXT
  SILENT
}

enum ResponderPreference {
  AI
  OPERATOR
}

enum CommunicationChannel {
  VOICE
  CHAT
}

enum ChannelSwitchReason {
  USER_CHOICE
  VOICE_ERROR
  CALL_ENDED
  OPERATOR_REQUEST
}

enum ReportClosureReason {
  PRANK_CALL
  INCOMPLETE_REPORT
  OTHER
}

enum CancellationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReportAcknowledgementType {
  HELP_VISIBLE
  WITH_RESPONDER
}

model EmergencyReport {
  id String @id @default(cuid())

  reporterId String
  reporter   User   @relation("ReportsAsReporter", fields: [reporterId], references: [id])

  accessToken    String  @unique @default(cuid())
  idempotencyKey String?
  version        Int     @default(1)

  status       ReportStatus   @default(SUBMITTED)
  category     ReportCategory @default(UNCATEGORIZED)
  incidentType IncidentType?

  title          String?
  summary        String?
  recommendation String?
  extractedData  Json?

  contactPhoneSnapshot String?
  latitude             Float?
  longitude            Float?
  address              String?

  activeChannel       CommunicationChannel?
  handlingMode        HandlingMode          @default(AI)
  interactionMode     InteractionMode?
  responderPreference ResponderPreference   @default(AI)

  assignedOperatorId String?
  assignedOperator   User?   @relation("ReportsAsOperator", fields: [assignedOperatorId], references: [id])

  closureReason      ReportClosureReason?
  closureNote        String?
  closedByOperatorId String?
  closedByOperator   User?                @relation("ReportsClosedByOperator", fields: [closedByOperatorId], references: [id])

  isDemo Boolean @default(false)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?
  closedAt   DateTime?

  messages             Message[]
  callSessions         CallSession[]
  modeEvents           ModeEvent[]
  acousticSignals      AcousticSignal[]
  recordings           RecordingAsset[]
  cancellationRequests CancellationRequest[]
  acknowledgements     ReportAcknowledgement[]
  statusHistory        ReportStatusEvent[]
  channelSwitches      ChannelSwitchEvent[]
  aiAnalyses           AIAnalysisSnapshot[]
  handoffEvents        HandoffEvent[]
  dispatches           DispatchRequest[]

  @@unique([reporterId, idempotencyKey])
  @@index([status, category])
  @@index([reporterId])
  @@index([assignedOperatorId])
  @@index([closedByOperatorId])
  @@map("emergency_report")
}

model ReportStatusEvent {
  id         String            @id @default(cuid())
  reportId   String
  report     EmergencyReport   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  fromStatus ReportStatus?
  toStatus   ReportStatus
  note       String?
  actorType  MessageSenderType
  actorId    String?
  createdAt  DateTime          @default(now())

  @@index([reportId])
  @@map("report_status_event")
}

model ChannelSwitchEvent {
  id          String                @id @default(cuid())
  reportId    String
  report      EmergencyReport       @relation(fields: [reportId], references: [id], onDelete: Cascade)
  fromChannel CommunicationChannel?
  toChannel   CommunicationChannel
  reason      ChannelSwitchReason
  switchedAt  DateTime              @default(now())

  @@index([reportId])
  @@map("channel_switch_event")
}

model HandoffEvent {
  id         String          @id @default(cuid())
  reportId   String
  report     EmergencyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  fromMode   HandlingMode
  toMode     HandlingMode
  operatorId String?
  operator   User?           @relation("HandoffOperator", fields: [operatorId], references: [id])
  reason     String?
  occurredAt DateTime        @default(now())

  @@index([reportId])
  @@map("handoff_event")
}

model CancellationRequest {
  id       String          @id @default(cuid())
  reportId String
  report   EmergencyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  requestedById String
  requestedBy   User                      @relation("CancellationRequestedBy", fields: [requestedById], references: [id])
  reason        String
  status        CancellationRequestStatus @default(PENDING)

  reviewedById String?
  reviewedBy   User?     @relation("CancellationReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  outcomeNote  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reportId, status])
  @@index([requestedById])
  @@index([reviewedById])
  @@map("cancellation_request")
}

model ReportAcknowledgement {
  id       String          @id @default(cuid())
  reportId String
  report   EmergencyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  reporterId String
  reporter   User                      @relation("ReportAcknowledgementReporter", fields: [reporterId], references: [id])
  type       ReportAcknowledgementType
  createdAt  DateTime                  @default(now())

  @@unique([reportId, type])
  @@index([reporterId])
  @@map("report_acknowledgement")
}
